# ──────────────────────────────────────────────
# AI Immunization Recorder — Notification System
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# PostgreSQL
DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/immunization_db

# FastAPI backend base URL
API_BASE_URL=http://localhost:8000

# ─── Twilio (SMS + WhatsApp) ───────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Phone number in E.164 format, e.g. +919876543210
TWILIO_FROM_PHONE=+1XXXXXXXXXX
# Twilio WhatsApp sandbox sender (sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Email (Gmail SMTP) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Use a Gmail App Password (not your login password)
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_gmail@gmail.com

# ─── Push Notifications ────────────────────────
PUSH_API_URL=https://your-push-endpoint.example.com/send

# ─── Scheduler ────────────────────────────────
# Daily job time (24h format, local timezone)
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0

# ─── Quiet Hours (no notifications sent during this window) ───
QUIET_HOUR_START=22   # 10 PM
QUIET_HOUR_END=7      # 7 AM
